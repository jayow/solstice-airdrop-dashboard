# Secrets / API keys
.env
.env.*
!.env.example

# Large generated data (3+ GB SQLite + caches + jsonl)
data/

# Per-wallet generated dashboard JSONs (28k+ files, regenerated by build_wallet_details.py)
server/wallets/

# Generated dashboard payloads (regenerated by server/build_*.py)
server/data.json
server/daily_totals.json

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
.venv/
venv/

# Node (in case any tooling lands)
node_modules/

# OS / editors
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*~

# Logs
*.log

# Legacy walker scripts (superseded by current walkers; contain hardcoded
# API keys from earlier dev — kept locally for reference but not shipped)
_legacy_walkers/

# Generated data for the Next.js web dashboard (regenerated by the build
# pipeline; ~54MB of per-wallet event JSONs + the main data.json payload)
web/public/data.json
web/public/events/
web/.next/
web/node_modules/
web/.vercel/

# Root-level Next or Node build artifacts
.next/
node_modules/

# Static-flares Vercel deploy staging dir (regenerated from server/ each deploy)
flares-deploy/
