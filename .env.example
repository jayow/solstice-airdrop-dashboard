# Solana RPC endpoints. rpc_helper rotates across all of them.
# Provide at least one Helius key; others are optional paid fallbacks.

# Helius (primary; supports DAS + Enhanced API)
HELIUS_API_KEY=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY
helius2=https://mainnet.helius-rpc.com/?api-key=YOUR_SECOND_KEY

# QuickNode (recommended for sustained heavy fetches)
quicknode=https://YOUR-ENDPOINT.solana-mainnet.quiknode.pro/YOUR_TOKEN/

# Other paid fallbacks (optional)
chainstack=https://solana-mainnet.core.chainstack.com/YOUR_TOKEN
alchemy=https://solana-mainnet.g.alchemy.com/v2/YOUR_KEY
solsticerpc=

# Solstice's airdrop fee collection address
FEE_ADDRESS=
